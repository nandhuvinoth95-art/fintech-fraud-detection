{
  "datasets": [
    {
      "name": "e62caab5",
      "displayName": "Live KPIs",
      "queryLines": [
        "-- Live Fraud KPI Cards (refresh: 30 sec)\r\n",
        "\r\n",
        "SELECT\r\n",
        "    COUNT(*)                                            AS total_transactions_today,\r\n",
        "    SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END)           AS fraud_transactions_today,\r\n",
        "    ROUND(\r\n",
        "        SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) * 1.0 / NULLIF(COUNT(*), 0),\r\n",
        "        4\r\n",
        "    )                                                   AS fraud_rate_pct,\r\n",
        "    SUM(CASE WHEN is_fraud THEN amount ELSE 0 END)      AS fraud_amount_inr,\r\n",
        "    SUM(amount)                                         AS total_volume_inr,\r\n",
        "    COUNT(DISTINCT CASE WHEN is_fraud THEN customer_id END) AS unique_fraud_customers\r\n",
        "FROM fintech_fraud.silver.silver_transactions_unified\r\n",
        "WHERE event_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 30 DAYS;"
      ]
    },
    {
      "name": "bf65ce4a",
      "displayName": "Minutely Trend",
      "queryLines": [
        "SELECT\r\n",
        "    DATE_FORMAT(event_timestamp, 'HH:mm')             AS txn_minute,\r\n",
        "    COUNT(*)                                          AS total_txns,\r\n",
        "    SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END)         AS fraud_txns\r\n",
        "FROM fintech_fraud.silver.silver_transactions_cleaned\r\n",
        "WHERE event_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 30 DAYS\r\n",
        "GROUP BY DATE_FORMAT(event_timestamp, 'HH:mm')\r\n",
        "ORDER BY txn_minute;"
      ]
    },
    {
      "name": "79476e1e",
      "displayName": "Fraud by Type",
      "queryLines": [
        "-- Fraud by Type (Pie/Donut)\r\n",
        "SELECT\r\n",
        "    COALESCE(fraud_type, 'UNKNOWN') AS fraud_type,\r\n",
        "    COUNT(*)                        AS fraud_count,\r\n",
        "    SUM(amount)                     AS total_fraud_amount,\r\n",
        "    ROUND(AVG(fraud_score), 3)      AS avg_confidence_score\r\n",
        "FROM fintech_fraud.silver.silver_transactions_unified\r\n",
        "WHERE is_fraud = true\r\n",
        "  AND event_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 30 DAYS\r\n",
        "GROUP BY fraud_type\r\n",
        "ORDER BY fraud_count DESC;"
      ]
    },
    {
      "name": "fbb40620",
      "displayName": "Live Alert Feed",
      "queryLines": [
        "-- Live Alert Feed (refresh: 30 sec)\r\n",
        "SELECT\r\n",
        "    DATE_FORMAT(alert_generated_at, 'yyyy-MM-dd hh:mm:ss a') AS `Alert Time`,\r\n",
        "    alert_severity                                           AS `Severity`,\r\n",
        "    customer_id                                              AS `Customer ID`,\r\n",
        "    fraud_type                                               AS `Trigger Rule`,\r\n",
        "    ROUND(amount, 2)                                         AS `Amount (₹)`,\r\n",
        "    fraud_score                                              AS `Confidence (%)`,\r\n",
        "    location_city                                            AS `City`\r\n",
        "FROM fintech_fraud.gold.gold_fraud_alerts_live\r\n",
        "ORDER BY alert_generated_at DESC\r\n",
        "LIMIT 50;"
      ]
    },
    {
      "name": "bca0ee8d",
      "displayName": "Impossible Travel Detections",
      "queryLines": [
        "SELECT\r\n",
        "    DATE_FORMAT(detected_at, 'hh:mm:ss a')    AS `Detected`,\r\n",
        "    customer_id                               AS `Compromised User`,\r\n",
        "    CONCAT(from_city, ' → ', to_city)         AS `Travel Route`,\r\n",
        "    ROUND(time_gap_hours * 60, 0)             AS `Minutes Elapsed`,\r\n",
        "    ROUND(distance_km, 0)                     AS `Distance (km)`,\r\n",
        "    ROUND(implied_speed_kmh, 0)               AS `Implied Speed (km/h)`,\r\n",
        "    impossible_travel_score                   AS `Confidence (%)`\r\n",
        "FROM fintech_fraud.gold.gold_impossible_travel\r\n",
        "WHERE implied_speed_kmh > 900 \r\n",
        "ORDER BY detected_at DESC\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "8047fee1",
      "displayName": "The Geographic Fraud Map",
      "queryLines": [
        "SELECT\r\n",
        "    CASE \r\n",
        "        WHEN location_city = 'Bangalore' THEN 'Bengaluru Urban'\r\n",
        "        WHEN location_city = 'Mumbai'    THEN 'Mumbai City'\r\n",
        "        WHEN location_city = 'Delhi'     THEN 'New Delhi'\r\n",
        "        ELSE location_city \r\n",
        "    END                                               AS mapped_city,\r\n",
        "    COUNT(*)                                          AS total_txns,\r\n",
        "    SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END)         AS fraud_count,\r\n",
        "    SUM(CASE WHEN is_fraud THEN amount ELSE 0 END)    AS fraud_exposure_inr\r\n",
        "FROM fintech_fraud.silver.silver_transactions_unified\r\n",
        "WHERE event_timestamp >= CURRENT_TIMESTAMP() - INTERVAL 7 DAYS\r\n",
        "GROUP BY mapped_city\r\n",
        "ORDER BY fraud_count DESC\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "21b40f45",
      "displayName": "SLA Tracker",
      "queryLines": [
        "SELECT\r\n",
        "    CASE layer_table \r\n",
        "        WHEN 'bronze_transactions' THEN '1. Bronze (Raw Ingestion)'\r\n",
        "        WHEN 'silver_transactions' THEN '2. Silver (Cleaned CDC)'\r\n",
        "        WHEN 'gold_fraud_alerts'   THEN '3. Gold (Alerts Target)'\r\n",
        "        ELSE layer_table\r\n",
        "    END                                          AS `Processing Layer`,\r\n",
        "    row_count                                    AS `Total Records`,\r\n",
        "    DATE_FORMAT(newest_record, 'hh:mm:ss a')     AS `Last Record Arrived`,\r\n",
        "    lag_minutes                                  AS `Current Lag (Minutes)`\r\n",
        "FROM fintech_fraud.gold.pipeline_health_metrics "
      ]
    },
    {
      "name": "754208b8",
      "displayName": "System Health Status",
      "queryLines": [
        "SELECT\r\n",
        "    CASE\r\n",
        "        WHEN MAX(lag_minutes) > 15 THEN 'CRITICAL ALERT'\r\n",
        "        WHEN MAX(lag_minutes) > 5  THEN 'WARNING: SLOW'\r\n",
        "        ELSE 'SYSTEM HEALTHY'\r\n",
        "    END AS `Overall Status`\r\n",
        "FROM fintech_fraud.gold.pipeline_health_metrics;"
      ]
    },
    {
      "name": "4532aee7",
      "displayName": "Throughput Volume",
      "queryLines": [
        "SELECT\r\n",
        "    MAX(row_count) AS `Total Ingested Events`\r\n",
        "FROM fintech_fraud.gold.pipeline_health_metrics\r\n",
        "WHERE layer_table = 'bronze_transactions';"
      ]
    },
    {
      "name": "6bc30ed3",
      "displayName": "Anomaly Detection Stats",
      "queryLines": [
        "SELECT\r\n",
        "    transaction_date AS `Date`,\r\n",
        "    -- 1. Normal trend line (only populated on normal days)\r\n",
        "    CASE WHEN is_anomaly = false THEN txn_count ELSE NULL END AS `Normal Volume`,\r\n",
        "    \r\n",
        "    -- 2. Anomaly points (only populated when an anomaly breaks the threshold)\r\n",
        "    CASE WHEN is_anomaly = true THEN txn_count ELSE NULL END AS `Anomalous Spike`,\r\n",
        "    \r\n",
        "    -- 3. The 7-Day moving baseline\r\n",
        "    ROUND(rolling_avg_txn_count, 0) AS `7-Day Average`\r\n",
        "FROM fintech_fraud.gold.anomaly_detection_stats\r\n",
        "WHERE transaction_date >= CURRENT_DATE() - INTERVAL 30 DAYS\r\n",
        "ORDER BY transaction_date ASC;"
      ]
    }
  ],
